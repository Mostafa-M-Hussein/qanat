# qanat config. copy to .env and fill in. never commit .env.

TZ=Africa/Cairo

# where aria2/metube drop files, and where jellyfin reads them.
# point them at the same path so a finished download appears in jellyfin
# instantly (no copy step).
DOWNLOADS_DIR=./files
MEDIA_DIR=./media
MUSIC_DIR=./media/Music

PUID=0
PGID=0

# aria2 rpc secret. generate with: openssl rand -hex 24
ARIA2_RPC_SECRET=CHANGE_ME_RUN_openssl_rand_hex_24

# bt listener. open this on your firewall for inbound peer connections.
ARIA2_BT_PORT=6888
ARIA2_DISK_CACHE=64M

# yt-dlp options as json. notable knobs:
#   "proxy": socks5 to bypass datacenter ip blocks (point at warp service)
#   "cookiefile": path inside container, set COOKIES_FILE below
#   "concurrent_fragment_downloads": helps a lot on high-latency links
METUBE_YTDL_OPTIONS={"writesubtitles":true,"subtitleslangs":["en","ar","-live_chat"],"cookiefile":"/cookies.txt","format":"bestvideo+bestaudio/best","merge_output_format":"mp4","concurrent_fragment_downloads":8}

# yt-dlp cookies file (export from a browser extension).
# needed for age-gated / member-only youtube content.
COOKIES_FILE=./examples/cookies.txt.example

METUBE_OUTPUT_TEMPLATE=%(uploader)s/%(title)s.%(ext)s

# public url jellyfin advertises to clients. match what caddy serves.
JELLYFIN_URL=https://jellyfin.example.com

DOMAIN=example.com
ACME_EMAIL=you@example.com

# basic-auth gate for ariang/metube. generate hash with:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-password'
BASIC_AUTH_USER=admin
BASIC_AUTH_HASH=CHANGE_ME_PASTE_BCRYPT_HASH

# cloudflare tunnel token (only if using --profile tunnel)
TUNNEL_TOKEN=

# opencloud admin password. set on first start, can't be changed easily after.
# pick something strong; the password policy enforces 8+ chars with mixed case.
OC_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# opencloud image tag. pin to a specific release for production.
OC_DOCKER_TAG=6.1.0

# uid:gid the opencloud container runs as. owns ./opencloud/{config,data}.
# pick a non-root uid that exists on your host (id -u youruser).
OC_UID_GID=1000:1000

# collabora online (--profile office). admin login for the collabora ui.
COLLABORA_ADMIN_USER=admin
COLLABORA_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# keycloak (--profile sso). see docs/sso.md for realm setup.
KEYCLOAK_ADMIN=kcadmin
KEYCLOAK_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
KC_DB_USERNAME=keycloak
KC_DB_PASSWORD=CHANGE_ME_DB_PASSWORD

# oauth2-proxy. client created in keycloak (qanat realm, see docs/sso.md).
# cookie secret: openssl rand -base64 32 | tr -- '+/' '-_' | head -c 32
OAUTH2_PROXY_CLIENT_ID=qanat-gate
OAUTH2_PROXY_CLIENT_SECRET=CHANGE_ME_FROM_KEYCLOAK
OAUTH2_PROXY_COOKIE_SECRET=CHANGE_ME_RUN_openssl_rand_base64_32
