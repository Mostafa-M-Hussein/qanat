# qanat config. copy to .env and fill in. never commit .env.

TZ=Africa/Cairo

# where files live. DOWNLOADS_DIR is a subdir of MEDIA_DIR by default, so
# anything aria2 or metube drops appears in jellyfin's library automatically.
MEDIA_DIR=./media
DOWNLOADS_DIR=./media/Downloads
MUSIC_DIR=./media/Music

PUID=0
PGID=0

# aria2 rpc secret. generate with: openssl rand -hex 24
ARIA2_RPC_SECRET=CHANGE_ME_RUN_openssl_rand_hex_24

# bt listener. open this on your firewall for inbound peer connections.
ARIA2_BT_PORT=6888
ARIA2_DISK_CACHE=64M

# yt-dlp options as json. notable knobs:
#   "proxy": socks5 (point at warp service when youtube blocks the vps ip)
#   "concurrent_fragment_downloads": helps a lot on high-latency links
METUBE_YTDL_OPTIONS={"writesubtitles":true,"subtitleslangs":["en","ar","-live_chat"],"cookiefile":"/cookies.txt","format":"bestvideo+bestaudio/best","merge_output_format":"mp4","concurrent_fragment_downloads":8}
METUBE_OUTPUT_TEMPLATE=%(uploader)s/%(title)s.%(ext)s
COOKIES_FILE=./examples/cookies.txt.example

# public url jellyfin advertises to clients.
JELLYFIN_URL=https://jellyfin.example.com

DOMAIN=example.com
ACME_EMAIL=you@example.com

# basic-auth for ariang/metube. generate hash:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'your-pw'
BASIC_AUTH_USER=admin
BASIC_AUTH_HASH=CHANGE_ME_PASTE_BCRYPT_HASH

# cloudflare tunnel token (--profile tunnel)
TUNNEL_TOKEN=

# opencloud admin password (8+ chars, mixed case + digit + special).
OC_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
OC_DOCKER_TAG=6.1.0
OC_UID_GID=1000:1000

# collabora office editor (--profile office).
COLLABORA_ADMIN_USER=admin
COLLABORA_ADMIN_PASSWORD=CHANGE_ME_STRONG_PASSWORD
