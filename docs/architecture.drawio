<mxfile host="app.diagrams.net" agent="qanat" version="24.0.0">
  <diagram name="qanat" id="qanat-architecture">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1000" math="0" shadow="0" background="#FAFAFA">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Title -->
        <mxCell id="title" value="qanat — VPS-as-buffer architecture" style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=26;fontStyle=1;fontColor=#1A237E;" vertex="1" parent="1">
          <mxGeometry x="40" y="20" width="1520" height="50" as="geometry" />
        </mxCell>
        <mxCell id="subtitle" value="run downloads + media on a fast vps. stream them back over a slow link." style="text;html=1;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=2;fontColor=#555555;" vertex="1" parent="1">
          <mxGeometry x="40" y="65" width="1520" height="24" as="geometry" />
        </mxCell>

        <!-- ============== LEFT: client side ============== -->
        <mxCell id="region_egypt" value="last-mile (egypt / mena)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FF9800;strokeWidth=2;fontSize=13;fontStyle=2;fontColor=#E65100;verticalAlign=top;dashed=1;" vertex="1" parent="1">
