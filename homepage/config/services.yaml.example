# Edit DOMAIN below to match what you set in .env, or use {{HOMEPAGE_VAR_DOMAIN}}
# with HOMEPAGE_VAR_DOMAIN exported from .env.

- downloads:
    - aria2:
        href: https://aria.example.com
        description: torrent + http downloader
        icon: aria2.png
        widget:
          type: aria2
          url: http://aria2:6800
          # rpc secret matches ARIA2_RPC_SECRET in .env
          # password: "{{HOMEPAGE_VAR_ARIA2_RPC_SECRET}}"
    - metube:
        href: https://metube.example.com
        description: yt-dlp web ui
        icon: metube.png

- media:
    - jellyfin:
        href: https://jellyfin.example.com
        description: video streaming
        icon: jellyfin.png
        widget:
          type: jellyfin
          url: http://jellyfin:8096
          # key: "{{HOMEPAGE_VAR_JELLYFIN_API_KEY}}"
    - navidrome:
        href: https://music.example.com
        description: music streaming
        icon: navidrome.png

- files:
    - opencloud:
        href: https://cloud.example.com
        description: files, sharing, sync
        icon: owncloud.png
