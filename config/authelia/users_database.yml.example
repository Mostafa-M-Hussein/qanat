---
# generate the password hash with:
#   docker run --rm authelia/authelia:latest authelia crypto hash generate argon2 --password 'your-pw'
# copy this file to users_database.yml and replace the hash + email.

users:
  admin:
    disabled: false
    displayname: "admin"
    password: "$argon2id$v=19$m=65536,t=3,p=4$REPLACE_ME"
    email: admin@example.com
    groups:
      - admins
