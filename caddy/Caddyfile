# ---------------------------------------------------------------
# OpenCloud - files + sharing. Has its own auth (admin user + ldap).
# ---------------------------------------------------------------
cloud.{$DOMAIN} {
    reverse_proxy opencloud:9200 {
        flush_interval -1
    }
    encode zstd gzip
    header {
        Strict-Transport-Security "max-age=31536000;"
        X-Content-Type-Options "nosniff"
    }
}

# ---------------------------------------------------------------
# Homepage - dashboard at the bare domain. Links out to everything else.
# ---------------------------------------------------------------
{$DOMAIN} {
    reverse_proxy homepage:3000
}

# ---------------------------------------------------------------
# Collabora online editor (profile: office). routes:
#   collabora.DOMAIN     - the editor itself, public
#   collaboration.DOMAIN - opencloud's WOPI bridge, internal-only path
# ---------------------------------------------------------------
collabora.{$DOMAIN} {
    reverse_proxy collabora:9980
}

collaboration.{$DOMAIN} {
    reverse_proxy collaboration:9300
}

# ---------------------------------------------------------------
# Keycloak (profile: sso) and the oauth2-proxy callback host.
# ---------------------------------------------------------------
auth.{$DOMAIN} {
    # if profile=sso (keycloak) is up, this serves keycloak.
    # if profile=authelia is up instead, change to: reverse_proxy authelia:9091
    reverse_proxy keycloak:8080
}

auth-gate.{$DOMAIN} {
    reverse_proxy oauth2-proxy:4180
}
