# caddy config for qanat. auto-renews tls via letsencrypt.

{
    email {$ACME_EMAIL}
}

# sso_gate: forward-auth via keycloak + oauth2-proxy (--profile sso)
(sso_gate) {
    forward_auth oauth2-proxy:4180 {
        uri /oauth2/auth
        copy_headers X-Auth-Request-User X-Auth-Request-Email X-Auth-Request-Preferred-Username
        @error status 401
        handle_response @error {
            redir * https://auth-gate.{$DOMAIN}/oauth2/start?rd={scheme}://{host}{uri} 302
        }
    }
}

# authelia_gate: forward-auth via authelia (--profile authelia)
# pick one or the other - don't use both at the same time.
(authelia_gate) {
    forward_auth authelia:9091 {
        uri /api/authz/forward-auth
        copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
        @error status 401
        handle_response @error {
            redir * https://auth.{$DOMAIN}/?rd={scheme}://{host}{uri} 302
        }
    }
}

# ---------------------------------------------------------------
# Jellyfin - public, but rate-limited to deter abuse.
# ---------------------------------------------------------------
jellyfin.{$DOMAIN} {
    reverse_proxy jellyfin:8096 {
        flush_interval -1
    }

    encode zstd gzip
    header {
        Strict-Transport-Security "max-age=31536000;"
        X-Content-Type-Options "nosniff"
        Referrer-Policy "no-referrer-when-downgrade"
    }
}

# ---------------------------------------------------------------
# AriaNG - private, basic-auth gated.
# ---------------------------------------------------------------
aria.{$DOMAIN} {
    # uncomment to switch from basic-auth to keycloak (--profile sso):
    # import sso_gate
    basic_auth {
        {$BASIC_AUTH_USER} {$BASIC_AUTH_HASH}
    }
    reverse_proxy ariang:6880

    # aria2 RPC endpoint (AriaNG calls /jsonrpc on same host)
    @rpc path /jsonrpc /jsonrpc/*
    handle @rpc {
        reverse_proxy aria2:6800
    }
}

# ---------------------------------------------------------------
# MeTube - private, basic-auth gated.
# ---------------------------------------------------------------
metube.{$DOMAIN} {
    # uncomment to switch from basic-auth to keycloak (--profile sso):
    # import sso_gate
    basic_auth {
        {$BASIC_AUTH_USER} {$BASIC_AUTH_HASH}
    }
    reverse_proxy metube:8081
}

