# caddy config for qanat. auto-renews tls via letsencrypt.

{
    email {$ACME_EMAIL}
}

# the bare domain serves the homepage dashboard.
{$DOMAIN} {
    reverse_proxy homepage:3000
}

# jellyfin - public, has its own login.
jellyfin.{$DOMAIN} {
    reverse_proxy jellyfin:8096 {
        flush_interval -1
    }
    encode zstd gzip
}

# ariang (aria2 ui) + the aria2 rpc on the same host.
# basic-auth so randoms can't queue downloads on your vps.
aria.{$DOMAIN} {
    basic_auth {
        {$BASIC_AUTH_USER} {$BASIC_AUTH_HASH}
    }
    @rpc path /jsonrpc /jsonrpc/*
    handle @rpc {
        reverse_proxy aria2:6800
    }
    reverse_proxy ariang:6880
}

# metube (yt-dlp ui).
metube.{$DOMAIN} {
    basic_auth {
        {$BASIC_AUTH_USER} {$BASIC_AUTH_HASH}
    }
    reverse_proxy metube:8081
}

# navidrome (--profile music). uncomment to expose.
# music.{$DOMAIN} {
#     reverse_proxy navidrome:4533
# }

# opencloud - files + sharing.
cloud.{$DOMAIN} {
    reverse_proxy opencloud:9200 {
        flush_interval -1
    }
    encode zstd gzip
}

# collabora online editor (--profile office).
collabora.{$DOMAIN} {
    reverse_proxy collabora:9980
}

collaboration.{$DOMAIN} {
    reverse_proxy collaboration:9300
}
